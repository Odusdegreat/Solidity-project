{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha", "chai"]
  },
  "include": [
    "hardhat.d.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "ignition/**/*.ts"
  ],
  "exclude": ["frontend", "node_modules", "artifacts", "cache", "dist"]
}
